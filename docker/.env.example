# StudyHub 환경변수
# VPS: /opt/envs/study.env → docker/.env 심링크

# 데이터 디렉토리 (docker-compose volume)
DATA_DIR=/opt/data/study

# school_sync 크롤링 인증
SCHOOL_USERNAME=학번
SCHOOL_PASSWORD=비밀번호

# AI Q&A (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# SyOps JWT 인증 (SyOps와 동일한 시크릿)
SYOPS_SECRET_KEY=syops-secret-key-here

# 개발 모드 (프로덕션에서는 제거)
# DEV_MODE=1
